name: Cleanup Old Workflow Runs

on:
  schedule:
    - cron: '0 */23 * * *'
  workflow_dispatch:
    inputs:
      clean_temp:
        description: "Delete temp_* folders"
        required: false
        default: "false"

jobs:
  cleanup-runs:
    runs-on: ubuntu-latest
    permissions:
      actions: write

    steps:
      - name: Delete old workflow runs
        uses: actions/github-script@v7
        with:
          script: |
            const { owner, repo } = context.repo;
            const workflow_id = 'download-split.yml';

            const runs = await github.paginate(
              github.rest.actions.listWorkflowRuns,
              { owner, repo, workflow_id, per_page: 100 }
            );

            for (const run of runs) {
              const age = (Date.now() - new Date(run.created_at).getTime()) / (1000 * 60 * 60 * 24);

              if (age > 7) {
                console.log(`Deleting run ${run.id} (age: ${age.toFixed(1)} days)`);
                await github.rest.actions.deleteWorkflowRun({
                  owner,
                  repo,
                  run_id: run.id
                });
              }
            }

            console.log("Workflow runs cleanup completed.");
